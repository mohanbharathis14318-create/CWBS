-- Expense Request -----------------------------------------------------------------------------------------------------
CREATE TABLE office_expense_requests (
    request_id SERIAL PRIMARY KEY,
    daily_activity_type VARCHAR(100) DEFAULT 'Office Expenses',
    particulars VARCHAR(100),
    expense_type VARCHAR(100),
    requested_by INT REFERENCES user_profile(user_id),
    amount_requested NUMERIC(12,2) NOT NULL,
    transaction_remark TEXT,
    payment_mode VARCHAR(50),
    priority_level VARCHAR(100),
    status VARCHAR(50) DEFAULT 'In Review' CHECK (status IN ('In Review', 'Approved', 'Denied', 'Received')),
    approved_by INT REFERENCES user_profile(user_id),
    forwarded_to INT REFERENCES user_profile(user_id),
    date_requested TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

SELECT * FROM office_expense_requests;

-- Transaction (Log)
CREATE TABLE transactions (
    transaction_id SERIAL PRIMARY KEY,
    linked_request_id INT REFERENCES office_expense_requests(request_id) ON DELETE CASCADE,
    paid_by INT REFERENCES user_profile(user_id),  -- Accountant
    paid_to INT REFERENCES user_profile(user_id),  -- SS / Individual
    amount_paid NUMERIC(12,2) NOT NULL,
    mode_of_payment VARCHAR(50) CHECK (mode_of_payment IN ('Cash')),
    notes TEXT,
    status VARCHAR(50) CHECK (status IN ('In Review', 'Approved', 'Denied', 'Received')),
    date_paid TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- General Ledger (Universal, instead of 3 separate)
CREATE TABLE general_ledger (
    ledger_id SERIAL PRIMARY KEY,
    user_id INT REFERENCES user_profile(user_id),   -- whose account
    counterparty_id INT REFERENCES user_profile(user_id), -- opposite side
    linked_request_id INT REFERENCES office_expense_requests(request_id),
    transaction_id INT REFERENCES transactions(transaction_id),
    type VARCHAR(20) CHECK (type IN ('Income', 'Expense')),
    source VARCHAR(20) CHECK (source IN ('Bank', 'Cash')),
    amount NUMERIC(12,2) NOT NULL,
    balance NUMERIC(12,2), -- running balance for user
    notes TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


CREATE TABLE md_ledger (
    ledger_id SERIAL PRIMARY KEY,
    md_id INT REFERENCES user_profile(user_id),
    to_user INT REFERENCES user_profile(user_id),
    amount NUMERIC(12,2),
    type VARCHAR(20) CHECK (type IN ('Income', 'Expense')),
    source VARCHAR(20) CHECK (source IN ('Bank', 'Cash')),
    balance NUMERIC(12,2),
    notes TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE accountant_ledger (
    ledger_id SERIAL PRIMARY KEY,
    accountant_id INT REFERENCES user_profile(user_id),
    from_md INT REFERENCES user_profile(user_id),
    to_user INT REFERENCES user_profile(user_id),
    amount NUMERIC(12,2),
    type VARCHAR(20) CHECK (type IN ('Inflow', 'Outflow')),
    balance NUMERIC(12,2),
    notes TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


CREATE TABLE user_ledger (
    ledger_id SERIAL PRIMARY KEY,
    user_id INT REFERENCES user_profile(user_id),
    inflow NUMERIC(12,2) DEFAULT 0,
    outflow NUMERIC(12,2) DEFAULT 0,
    balance NUMERIC(12,2),
    notes TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


