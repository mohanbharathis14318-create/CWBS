---Labour Table --------------------------------------------------------------------------------------------------------
CREATE TABLE labour_master
(
    labour_id SERIAL NOT NULL PRIMARY KEY,
    project_name VARCHAR(100),
    total_mason_cost NUMERIC(15, 2),
    total_centering_cost NUMERIC(15, 2),
    total_plumbing_cost NUMERIC(15, 2),
    total_electrical_cost NUMERIC(15, 2),
    total_tiles_cost NUMERIC(15, 2),
    total_carpenter_cost NUMERIC(15, 2),
    total_painter_cost NUMERIC(15, 2),
    total_other_cost NUMERIC(15, 2),
    total_labour_cost NUMERIC(15, 2),
    created_by INT NOT NULL REFERENCES user_profile(user_id) ON DELETE SET NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

--Mason Table
CREATE TABLE mason_master
(
    mason_id SERIAL NOT NULL PRIMARY KEY,
    labour_id INT NOT NULL REFERENCES labour_master(labour_id) ON DELETE CASCADE,

    mason_name VARCHAR(100),
    mason_phone NUMERIC(15, 2),
    mason_address VARCHAR(100),

    mason_contract NUMERIC(15, 2),
    mason_contract_amount NUMERIC(15, 2),

    mason_basement VARCHAR(100),
    mason_basement_amount NUMERIC(15, 2),

    mason_lintel VARCHAR(100),
    mason_lintel_amount NUMERIC(15, 2),

    mason_roof VARCHAR(100),
    mason_roof_amount NUMERIC(15, 2),

    mason_outer_plastering VARCHAR(100),
    mason_outer_plastering_amount NUMERIC(15, 2),

    mason_inner_plastering VARCHAR(100),
    mason_inner_plastering_amount NUMERIC(15, 2),

    mason_septic_tank VARCHAR(100),
    mason_septic_tank_amount NUMERIC(15, 2),

    mason_s_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    mason_s_gst_amount NUMERIC(12, 2) DEFAULT 0.00,
    mason_c_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    mason_c_gst_amount NUMERIC(12, 2) DEFAULT 0.00,
    mason_i_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    mason_i_gst_amount NUMERIC(12, 2) DEFAULT 0.00,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


-- Centering Table -----------------------------------------------------------------------------------------------------
CREATE TABLE centering_master
(
    centering_id SERIAL NOT NULL PRIMARY KEY,
    labour_id INT NOT NULL REFERENCES labour_master(labour_id) ON DELETE CASCADE,

    centering_name VARCHAR(100),
    centering_phone NUMERIC(15, 2),
    centering_address VARCHAR(100),

    centering_contract NUMERIC(15, 2),
    centering_contract_amount NUMERIC(15, 2),

    footing_ground VARCHAR(100),
    footing_ground_amount NUMERIC(15, 2),

    plinth_beam VARCHAR(100),
    plinth_beam_amount NUMERIC(15, 2),

    basement_column VARCHAR(100),
    basement_column_amount NUMERIC(15, 2),

    outer_plastering VARCHAR(100),
    outer_plastering_amount NUMERIC(15, 2),

    feet_column VARCHAR(100),
    feet_column_amount NUMERIC(15, 2),

    lintel_beam VARCHAR(100),
    lintel_beam_amount NUMERIC(15, 2),

    after_lintel_column VARCHAR(100),
    after_lintel_column_amount NUMERIC(15, 2),

    hide_beam VARCHAR(100),
    hide_beam_amount NUMERIC(15, 2),

    centering_roof VARCHAR(100),
    centering_roof_amount NUMERIC(15, 2),

    roof_beam VARCHAR(100),
    roof_beam_amount NUMERIC(15, 2),

    centering_s_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    centering_s_gst_amount NUMERIC(12, 2) DEFAULT 0.00,
    centering_c_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    centering_c_gst_amount NUMERIC(12, 2) DEFAULT 0.00,
    centering_i_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    centering_i_gst_amount NUMERIC(12, 2) DEFAULT 0.00,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Centering Items
CREATE TABLE centering_items (

    centering_item_id SERIAL NOT NULL PRIMARY KEY,
    centering_id INT REFERENCES centering_master(centering_id) ON DELETE CASCADE,

    centering_item_name VARCHAR(100),
    centering_item_amount NUMERIC(15, 2),
    centering_item_remarks TEXT,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

