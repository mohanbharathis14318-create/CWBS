-- Create User Table For CoreBuild
CREATE TABLE user_profile
(
    user_id SERIAL NOT NULL PRIMARY KEY ,
    full_name VARCHAR(50) NOT NULL ,
    user_email TEXT UNIQUE NOT NULL CHECK ( user_email ~* '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$' ),
    phone TEXT UNIQUE NOT NULL CHECK ( phone ~ '^\+?[0-9]{10,15}$' ),
    user_password bytea NOT NULL,
    user_designation VARCHAR(50),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Create Suppliers Table For CoreBuild
CREATE TABLE supplier_profile
(
    supplier_id SERIAL NOT NULL PRIMARY KEY ,
    full_name VARCHAR(50) NOT NULL ,
    phone TEXT NOT NULL CHECK ( phone ~ '^\+?[0-9]{10,15}$' ),
    company_name TEXT NOT NULL,
    company_type TEXT NOT NULL,
    business_type VARCHAR(50) NOT NULL ,
    gst_number varchar(50) NOT NULL,
    pan_number VARCHAR(50) NOT NULL ,
    bank_name TEXT,
    bank_account_number VARCHAR(50),
    ifsc_code VARCHAR(50),
    upi_number TEXT UNIQUE NOT NULL CHECK ( phone ~ '^\+?[0-9]{10,15}$' ),
    supplier_address TEXT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Create Bank Table For CoreBuild
CREATE TABLE bank_details
(
    bank_id SERIAL NOT NULL PRIMARY KEY,
    bank_holder_name TEXT NOT NULL,
    ifsc_code TEXT NOT NULL,
    bank_account_no VARCHAR(50) NOT NULL,
    bank_name TEXT NOT NULL,
    bank_branch_name TEXT NOT NULL,
    bank_amount NUMERIC(12, 2) NOT NULL,
    cash NUMERIC(12, 2) NOT NULL,
    account_type TEXT NOT NULL,
    created_by INTEGER REFERENCES user_profile(user_id) ON DELETE SET NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Bank Audit Ledger
CREATE TABLE bank_ledger (
    ledger_id SERIAL PRIMARY KEY,
    bank_id INT REFERENCES bank_details(bank_id) ON DELETE CASCADE,
    trxn_id INT REFERENCES expense_requests(trxn_id) ON DELETE CASCADE,
    flow_type TEXT NOT NULL, -- "OUT" for Approved, "IN" for Returned
    payment_mode TEXT NOT NULL, -- Cash, Bank, UPI
    amount NUMERIC(12,2) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Create Budget Table
CREATE TABLE budget_details
(
    budget_id SERIAL NOT NULL PRIMARY KEY,
    budget_month TEXT NOT NULL,
    budget_expenses_type TEXT NOT NULL,
    budget_particulars TEXT NOT NULL,
    budget_amount NUMERIC(12, 2) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Create Office Account Investment Table
CREATE TABLE account_office_investment
(
    aci_id SERIAL NOT NULL PRIMARY KEY,
    aci_daily_activity_type TEXT NOT NULL,
    aci_date TEXT NOT NULL,
    aci_particulars TEXT NOT NULL,
    aci_investment_type TEXT NOT NULL,
    aci_amount TEXT NOT NULL,
    aci_payment_mode TEXT NOT NULL,
    aci_transaction_remark TEXT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Create Office Account Expense Table
CREATE TABLE office_expenses (
    expense_id SERIAL PRIMARY KEY,

    daily_activity_type VARCHAR(100) DEFAULT 'Office Expenses',
    date DATE NOT NULL,
    particulars TEXT,
    type VARCHAR(50),

    base_amount NUMERIC(12, 2) DEFAULT 0.00,
    payment_mode VARCHAR(50),
    transaction_remark TEXT,
    discount NUMERIC(12, 2) DEFAULT 0.00,

    s_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    s_gst_amount NUMERIC(12, 2) DEFAULT 0.00,
    c_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    c_gst_amount NUMERIC(12, 2) DEFAULT 0.00,
    i_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    i_gst_amount NUMERIC(12, 2) DEFAULT 0.00,

    total_amount NUMERIC(12, 2) DEFAULT 0.00,

    created_by INT REFERENCES user_profile(user_id) ON DELETE SET NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Create Cash In Hand Table
CREATE TABLE cih_details
(
    cih_id  SERIAL NOT NULL PRIMARY KEY,
    daily_activity TEXT NOT NULL,
    cih_transaction_type TEXT NOT NULL,
    cih_holders_name TEXT NOT NULL,
    cih_designation TEXT NOT NULL,
    cih_remarks TEXT NOT NULL,
    cih_amount NUMERIC(14, 2) NOT NULL,
    created_by INTEGER REFERENCES user_profile(user_id) ON DELETE SET NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Create Trxn Request Table
CREATE TABLE cih_trxn_requests (
    trxn_id SERIAL PRIMARY KEY,
    daily_activity_type VARCHAR(100),
    requirement_type VARCHAR(100),

    user_name VARCHAR(100) NOT NULL,
    user_designation VARCHAR(100),
    transaction_type VARCHAR(50),
    trxn_remarks TEXT,
    payment_mode VARCHAR(50),
    expense_type VARCHAR(50),
    amount NUMERIC(12, 2),
    status VARCHAR(20) DEFAULT 'Pending',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Create Trxn Expense Request
CREATE TABLE expense_requests (
                                  trxn_id SERIAL PRIMARY KEY,
                                  daily_activity_type VARCHAR(100),
                                  requirement_type VARCHAR(100),

    -- General Request Info
                                  transaction_title VARCHAR(255) NOT NULL,
                                  trxn_remarks TEXT NOT NULL,
                                  user_name VARCHAR(150) NOT NULL,
                                  user_designation VARCHAR(50) NOT NULL,
                                  payment_mode VARCHAR(50) NOT NULL, -- UPI / Bank / Cash
                                  expense_type VARCHAR(50) NOT NULL, -- Direct / Indirect
                                  amount NUMERIC(15,2) NOT NULL,
                                  status VARCHAR(20) DEFAULT 'Pending',
                                  cash_flow_type VARCHAR(50) NOT NULL, -- Cash Given / Cash Return

    -- Cash Given Fields
                                  given_datetime TEXT NULL,
                                  given_sender_name VARCHAR(150) NULL,
                                  given_sender_designation VARCHAR(50) NULL,
                                  given_payment_mode VARCHAR(50) NULL,
                                  given_amount NUMERIC(15,2) NULL,

    -- Cash Return Fields
                                  return_datetime TEXT NULL,
                                  return_receiver_name VARCHAR(150) NULL,
                                  return_receiver_designation VARCHAR(50) NULL,
                                  return_payment_mode VARCHAR(50) NULL,
                                  total_requested_amount NUMERIC(15,2) NULL,
                                  total_expensed_amount NUMERIC(15,2) NULL,
                                  total_balance_amount NUMERIC(15,2) NULL,
                                  total_return_amount NUMERIC(15,2) NULL,

    -- Audit Fields
                                  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

--------------------------------------------------------------------------------------

--Project
CREATE TABLE project_table (
    project_id SERIAL PRIMARY KEY,
    start_date TEXT,
    end_date TEXT,
    project_name VARCHAR(100),
    project_area NUMERIC(15,2),
    rate_per_sqft NUMERIC(15,2),
    area_sqft NUMERIC(15,2),
    construction_cost NUMERIC(15,2),
    construction_budget NUMERIC(15,2),
    septic_tank NUMERIC(15,2),

    s_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    s_gst_amount NUMERIC(12, 2) DEFAULT 0.00,
    c_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    c_gst_amount NUMERIC(12, 2) DEFAULT 0.00,
    i_gst_percent NUMERIC(5, 2) DEFAULT 0.00,
    i_gst_amount NUMERIC(12, 2) DEFAULT 0.00,

    plot_cost NUMERIC(15,2),
    plot_sqft NUMERIC(15,2),

    project_remarks VARCHAR(150),
    status VARCHAR(20) DEFAULT 'Inline',
    created_by INT NOT NULL REFERENCES user_profile(user_id) ON DELETE CASCADE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Amenities Table
CREATE TABLE amenities
(
    amenitiy_id SERIAL PRIMARY KEY,
    project_id INT NOT NULL REFERENCES project_table(project_id) ON DELETE CASCADE,
    amenities_item VARCHAR(100) NOT NULL,
    amenities_amount NUMERIC(15,2) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Extra Items
CREATE TABLE extra_items
(
    extra_id SERIAL PRIMARY KEY,
    project_id INT NOT NULL REFERENCES project_table(project_id) ON DELETE CASCADE,
    extra_item VARCHAR(100) NOT NULL,
    extra_amount NUMERIC(15,2) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

--- Doc Charges
CREATE TABLE documents
(
    doc_id SERIAL PRIMARY KEY,
    project_id INT NOT NULL REFERENCES project_table(project_id) ON DELETE CASCADE,
    doc_item VARCHAR(100) NOT NULL,
    doc_amount NUMERIC(15,2) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

