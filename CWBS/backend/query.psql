------------------------------------------------------------------------------------------------------------------------
CREATE TABLE expense_requests (
    trxn_id SERIAL PRIMARY KEY,
    daily_activity_type VARCHAR(100),
    requirement_type VARCHAR(100),
    transaction_title VARCHAR(255) NOT NULL,
    trxn_remarks TEXT NOT NULL,
    user_name VARCHAR(150) NOT NULL,
    user_designation VARCHAR(50) NOT NULL,
    payment_mode VARCHAR(50) NOT NULL,   -- UPI / Bank / Cash
    expense_type VARCHAR(50) NOT NULL,   -- Direct / Indirect
    amount NUMERIC(15,2) NOT NULL,
    status VARCHAR(20) DEFAULT 'Pending',
    cash_flow_type VARCHAR(50) NOT NULL, -- Cash Given / Cash Return
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Cah Given
CREATE TABLE cash_given (
    given_id SERIAL PRIMARY KEY,
    trxn_id INT NOT NULL REFERENCES expense_requests(trxn_id) ON DELETE CASCADE,
    given_date TEXT,
    given_sender_name VARCHAR(150),
    given_sender_designation VARCHAR(50),
    given_payment_mode VARCHAR(50),
    given_amount NUMERIC(15,2)
);

-- Cash Return
CREATE TABLE cash_return (
    return_id SERIAL PRIMARY KEY,
    trxn_id INT NOT NULL REFERENCES expense_requests(trxn_id) ON DELETE CASCADE,
    return_date TEXT,
    return_sender_name VARCHAR(150),
    return_sender_designation VARCHAR(50),
    return_payment_mode VARCHAR(50),
    total_requested_amount NUMERIC(15,2),
    total_expensed_amount NUMERIC(15,2),
    total_balance_amount NUMERIC(15,2),
    total_return_amount NUMERIC(15,2)
);

-- Expense Items for Cash Return
CREATE TABLE expense_items (
    expense_id SERIAL PRIMARY KEY,
    return_id INT NOT NULL REFERENCES cash_return(return_id) ON DELETE CASCADE,
    expense_description TEXT NOT NULL,
    expense_amount NUMERIC(15,2) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

